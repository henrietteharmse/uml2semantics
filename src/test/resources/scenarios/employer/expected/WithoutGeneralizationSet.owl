    <!-- https://uml2semantics.com/ontology/Renumeration#paymentSchedule -->


    <owl:ObjectProperty rdf:about="https://uml2semantics.com/ontology/Renumeration#paymentSchedule">
        <rdfs:domain rdf:resource="https://uml2semantics.com/ontology/Renumeration"/>
        <rdfs:range rdf:resource="https://uml2semantics.com/ontology/PaymentSchedule"/>
        <rdfs:label>paymentSchedule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 

    <!-- https://uml2semantics.com/ontology/Person#dateOfBirth -->


    <owl:DatatypeProperty rdf:about="https://uml2semantics.com/ontology/Person#dateOfBirth">
        <rdfs:domain rdf:resource="https://uml2semantics.com/ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The date on which this person was born.</rdfs:comment>
        <rdfs:label>dateOfBirth</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://uml2semantics.com/ontology/Person#name -->


    <owl:DatatypeProperty rdf:about="https://uml2semantics.com/ontology/Person#name">
        <rdfs:domain rdf:resource="https://uml2semantics.com/ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The given name of the person. A person can have more than 1 name.</rdfs:comment>
        <rdfs:label>name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://uml2semantics.com/ontology/Person#surname -->


    <owl:DatatypeProperty rdf:about="https://uml2semantics.com/ontology/Person#surname">
        <rdfs:domain rdf:resource="https://uml2semantics.com/ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The family name of the person.</rdfs:comment>
        <rdfs:label>surname</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://uml2semantics.com/ontology/Renumeration#rate -->


    <owl:DatatypeProperty rdf:about="https://uml2semantics.com/ontology/Renumeration#rate">
        <rdfs:domain rdf:resource="https://uml2semantics.com/ontology/Renumeration"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>rate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://uml2semantics.com/ontology/Employee -->


    <owl:Class rdf:about="https://uml2semantics.com/ontology/Employee">
        <rdfs:subClassOf rdf:resource="https://uml2semantics.com/ontology/Person"/>
        <owl:disjointWith rdf:resource="https://uml2semantics.com/ontology/Employer"/>
        <rdfs:comment>An employee is someone who does work for an employer for which they get compensated.</rdfs:comment>
        <rdfs:label>Employee</rdfs:label>
    </owl:Class>
    


    <!-- https://uml2semantics.com/ontology/Employer -->


    <owl:Class rdf:about="https://uml2semantics.com/ontology/Employer">
        <rdfs:subClassOf rdf:resource="https://uml2semantics.com/ontology/Person"/>
        <rdfs:comment>An employer is someone that employs 1 or more persons.</rdfs:comment>
        <rdfs:label>Employer</rdfs:label>
    </owl:Class>
    


    <!-- https://uml2semantics.com/ontology/PaymentSchedule -->


    <owl:Class rdf:about="https://uml2semantics.com/ontology/PaymentSchedule">
        <rdfs:label>PaymentSchedule</rdfs:label>
    </owl:Class>
    


    <!-- https://uml2semantics.com/ontology/Person -->


    <owl:Class rdf:about="https://uml2semantics.com/ontology/Person">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://uml2semantics.com/ontology/Person#name"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://uml2semantics.com/ontology/Person#dateOfBirth"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://uml2semantics.com/ontology/Person#surname"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A person is a &lt;b&gt;human being&lt;/b&gt;.

Human beings are also referred to as homo sapiens or modern humans.


</rdfs:comment>
        <rdfs:label>Person</rdfs:label>
    </owl:Class>
    


    <!-- https://uml2semantics.com/ontology/Renumeration -->


    <owl:Class rdf:about="https://uml2semantics.com/ontology/Renumeration">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://uml2semantics.com/ontology/Renumeration#paymentSchedule"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://uml2semantics.com/ontology/Renumeration#rate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Renumeration</rdfs:label>
    </owl:Class>
    



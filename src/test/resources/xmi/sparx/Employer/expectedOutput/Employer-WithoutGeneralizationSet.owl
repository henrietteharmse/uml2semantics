    <!-- http://uml2semantics.org/examples/employer#paymentSchedule -->


    <owl:ObjectProperty rdf:about="http://uml2semantics.org/examples/employer#paymentSchedule">
        <rdfs:domain rdf:resource="http://uml2semantics.org/examples/employer#Renumeration"/>
        <rdfs:range rdf:resource="http://uml2semantics.org/examples/employer#PaymentSchedule"/>
        <rdfs:label>paymentSchedule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
